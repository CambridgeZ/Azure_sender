# ===== Azure Event Hub =====
# 方式 1：连接字符串 (Connection String)
EVENT_HUB_CONNECTION_STR="Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<KeyName>;SharedAccessKey=<Key>"
EVENT_HUB_NAME="<your-event-hub-name>"

# 方式 2：Azure AD (DefaultAzureCredential)
# 设置后会优先使用 AAD；需要 az login 或托管标识等
EVENT_HUB_FULLY_QUALIFIED_NAMESPACE="<namespace>.servicebus.windows.net"
# 留空表示使用 EVENT_HUB_CONNECTION_STR
USE_AAD_FOR_EVENT_HUB="false"

# ===== Azure IoT Hub (设备) =====
# 推荐：直接给出 Device Connection String，库会自动从中派生 SAS Token
IOT_HUB_DEVICE_CONNECTION_STR="HostName=<hub>.azure-devices.net;DeviceId=<device-id>;SharedAccessKey=<key>"

# 或者：使用 SAS Token 模式（手动签发）
IOT_HUB_HOSTNAME="<hub>.azure-devices.net"
IOT_HUB_DEVICE_ID="<device-id>"
IOT_HUB_DEVICE_KEY="<base64-device-symmetric-key>"
# SAS Token 过期时间（秒），默认 1 小时
IOT_HUB_SAS_TTL="3600"
